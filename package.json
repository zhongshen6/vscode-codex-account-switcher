{
  "name": "codex-account-switcher",
  "displayName": "Codex 账号切换器",
  "description": "切换 Codex 账号，查看配额，自动续期，并在切号后重载 Codex。",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*",
    "onStartupFinished",
    "onCommand:codexAccountSwitcher.switchAccount",
    "onCommand:codexAccountSwitcher.refreshAccounts",
    "onCommand:codexAccountSwitcher.deleteAccount",
    "onCommand:codexAccountSwitcher.applyCodexPatch",
    "onCommand:codexAccountSwitcher.restoreCodexPatch"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codexAccountSwitcher.switchAccount",
        "title": "Codex 账号切换器：切换账号"
      },
      {
        "command": "codexAccountSwitcher.refreshAccounts",
        "title": "Codex 账号切换器：刷新状态"
      },
      {
        "command": "codexAccountSwitcher.deleteAccount",
        "title": "Codex 账号切换器：删除已保存账号"
      },
      {
        "command": "codexAccountSwitcher.applyCodexPatch",
        "title": "Codex 账号切换器：应用 Codex 补丁"
      },
      {
        "command": "codexAccountSwitcher.restoreCodexPatch",
        "title": "Codex 账号切换器：恢复 Codex 补丁"
      }
    ],
    "configuration": {
      "title": "Codex 账号切换器",
      "properties": {
        "codexAccountSwitcher.autoReloadCodexAfterSwitch": {
          "type": "boolean",
          "default": true,
          "description": "切换账号后自动重载 Codex。"
        },
        "codexAccountSwitcher.autoRefreshTokensForInactiveAccounts": {
          "type": "boolean",
          "default": true,
          "description": "允许对非当前账号自动续期 access token。"
        },
        "codexAccountSwitcher.autoRefreshQuota": {
          "type": "boolean",
          "default": true,
          "description": "在后台定时刷新已保存账号的配额信息。"
        },
        "codexAccountSwitcher.quotaRefreshIntervalMinutes": {
          "type": "number",
          "default": 60,
          "minimum": 1,
          "description": "后台自动刷新配额的时间间隔，单位为分钟。"
        },
        "codexAccountSwitcher.quotaRequestMinIntervalMs": {
          "type": "number",
          "default": 1500,
          "minimum": 0,
          "description": "连续发起配额请求之间的最小间隔，单位为毫秒。"
        },
        "codexAccountSwitcher.sortBy": {
          "type": "string",
          "default": "quota",
          "enum": [
            "quota",
            "displayName",
            "email"
          ],
          "enumDescriptions": [
            "按配额排序，先比较 5h，再比较周配额。",
            "按显示名排序。",
            "按邮箱排序。"
          ],
          "description": "账号选择框的排序方式。"
        },
        "codexAccountSwitcher.sortDescending": {
          "type": "boolean",
          "default": false,
          "description": "是否使用倒序排序。对配额排序来说，关闭时低额度在前，开启时高额度在前。"
        }
      }
    }
  }
}
